{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/coach.js": {
      "memory": 256,
      "maxDuration": 30
    },
    "api/weather.js": {
      "memory": 256,
      "maxDuration": 15
    }
  }
}